{
  "name": "templater",
  "version": "0.3.1",
  "description": "Templater — personal desk-side app for prose templating with semantic paste-to-match via the Claude Agent SDK.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:sidecar": "cd sidecar && npm run build",
    "build:sidecar:prod": "node scripts/build-sidecar-prod.mjs",
    "fetch:node": "node scripts/fetch-node-binary.mjs",
    "build:bundle": "npm run fetch:node && npm run build && npm run build:sidecar:prod",
    "release:manifest": "node scripts/make-release-manifest.mjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
