{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Templater",
  "version": "0.9.6",
  "identifier": "com.noel.templatewidget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AbstractNucleus/templater/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCRTVGQjA0MEY0N0M3OTEKUldTUngwY1BCUHZsdTlYN3hPMFJYc1R1YmR4NERtSU0wT2dpSVFWc1ovZzk1YnVIbkxhUElKU1IK"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Templater",
        "width": 800,
        "height": 600,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "minWidth": 480,
        "minHeight": 360,
        "dragDropEnabled": false
      },
      {
        "label": "preview",
        "title": "Templater — Preview",
        "url": "/preview",
        "width": 460,
        "height": 600,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "minWidth": 320,
        "minHeight": 240,
        "dragDropEnabled": false,
        "resizable": true
      },
      {
        "label": "translator",
        "title": "Templater — Translate",
        "url": "/translator",
        "width": 460,
        "height": 360,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "minWidth": 320,
        "minHeight": 200,
        "dragDropEnabled": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'unsafe-inline' 'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "app", "dmg"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
